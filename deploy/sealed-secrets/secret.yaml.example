# DO NOT COMMIT secret.yaml — only sealed-secret.yaml goes in git.
# Usage: cp secret.yaml.example secret.yaml && kubeseal < secret.yaml > sealed-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: yomochi-secrets
  namespace: default
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://USER:PASS@HOST:5432/yomochi"
  REDIS_URL: "redis://HOST:6379/0"
  KAFKA_BOOTSTRAP_SERVERS: "HOST:9092"
  OPENAI_API_KEY: "sk-..."
  JWT_SECRET: "change-me-to-a-random-64-char-string"
