# CloudNativePG app user credentials.
# The password here must match CHANGE_ME_PASSWORD in secret.yaml.example.
# CloudNativePG reads this secret during initdb to create the `app` role.
#
# DO NOT COMMIT pg-user-secret.yaml — only pg-user-sealed-secret.yaml goes in git.
# Usage:
#   cp pg-user-secret.yaml.example pg-user-secret.yaml
#   $EDITOR pg-user-secret.yaml   # set password
#   kubeseal --format yaml --controller-namespace sealed-secrets \
#     < pg-user-secret.yaml > pg-user-sealed-secret.yaml
#   kubectl apply -f pg-user-sealed-secret.yaml
#   shred -u pg-user-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: yomochi-pg-user
  namespace: yomochi
type: Opaque
stringData:
  username: "app"
  password: "CHANGE_ME_PASSWORD"
