[importlinter]
root_packages =
    app
    tests

# Third-party import exceptions documented here (import-linter governs internal layer deps,
# not third-party packages; these notes record intentional exceptions for future reviewers):
#
# opentelemetry in application layer (bugs.md B37 — accepted exception, 2026-06-12):
#   app/application/insights/use_cases/_process_insight_steps.py
#   app/application/insights/use_cases/process_insight.py
#
#   opentelemetry API is allowed in the application layer as ambient observability,
#   analogous to logging/structlog — all trace calls are no-ops without an SDK
#   configured (ProxyTracerProvider). Wrapping in a Tracer port would add a port +
#   adapter for zero behaviour change. See bugs.md B37 for the full trade-off record.

[importlinter:contract:layers]
name = Clean architecture layers
type = layers
layers =
    app.main
    app.inbound
    app.outbound
    app.application
    app.domain

[importlinter:contract:process-roots-independence]
name = Composition roots do not import each other
type = independence
modules =
    app.main.api
    app.main.outbox
    app.main.insight
    app.main.scheduler

[importlinter:contract:inbound-outbound-siblings]
name = Inbound and outbound do not import each other
type = forbidden
source_modules =
    app.inbound
forbidden_modules =
    app.outbound
ignore_imports =
    app.inbound.http.middleware.rate_limit -> app.outbound.observability.prometheus

[importlinter:contract:outbound-inbound-siblings]
name = Outbound does not import from inbound
type = forbidden
source_modules =
    app.outbound
forbidden_modules =
    app.inbound

[importlinter:contract:modules]
name = Bounded context independence (application layer)
type = independence
modules =
    app.application.users
    app.application.transactions
    app.application.categories
    app.application.insights
    app.application.search
    app.application.alerts
    app.application.chat
    app.application.ingestion

[importlinter:contract:outbound-modules]
name = Bounded context independence (outbound adapters)
type = independence
modules =
    app.outbound.adapters.sqla.users
    app.outbound.adapters.sqla.transactions
    app.outbound.adapters.sqla.categories
    app.outbound.adapters.sqla.insights
    app.outbound.adapters.sqla.search
    app.outbound.adapters.sqla.alerts
    app.outbound.adapters.sqla.chat
