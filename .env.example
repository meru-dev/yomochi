# Example .env for local development
# Copy this file to `.env` and update the secrets before running `docker compose up`.

# ---------------------------
# Database
# ---------------------------
POSTGRES_USER=yomochi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yomochi
DATABASE_URL=postgresql+asyncpg://yomochi:changeme@postgres:5432/yomochi

# ---------------------------
# Redis
# ---------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------
# Kafka
# ---------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---------------------------
# OpenTelemetry / Observability
# ---------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_ENABLED=true
OTEL_SERVICE_NAME=yomochi-api
# Workers expose Prometheus exporter on METRICS_PORT (api mounts /metrics on 8000).
METRICS_ENABLED=true
METRICS_PORT=9090

# ---------------------------
# Logging
# ---------------------------
LOG_FORMAT=json

# ---------------------------
# OpenAI (LLM) - provide your API key here for features that call OpenAI
# ---------------------------
# Example: OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
# Default model names used by the app (override if you prefer other models)
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_EMBED=text-embedding-3-small

# ---------------------------
# Authentication / Security
# ---------------------------
# Min 32 bytes required (RFC 7518 §3.2). Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-plus-byte-secret-generated-via-openssl

# ---------------------------
# Grafana (local) admin credentials
# ---------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# ---------------------------
# Optional developer overrides
# ---------------------------
# If you want web to be reachable on a different host port, set WEB_HOST_PORT (default 3100)
WEB_HOST_PORT=3100
# If you want the API to be reachable on a different host port, set API_HOST_PORT (default 8000)
API_HOST_PORT=8000

# ---------------------------
# Ingestion (receipt parser) — V2
# ---------------------------
INGESTION_MAX_UPLOAD_SIZE_MB=5
INGESTION_IMAGE_PROCESSING_CONCURRENCY=3
